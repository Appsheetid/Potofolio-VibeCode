    <!-- Contact / CTA -->
    <section id="contact" class="cta-section" aria-labelledby="contact-title">
      <div class="container">
        <span class="section-tag" style="color: rgba(255,255,255,0.6);">Mulai Proyek</span>
        <h2 id="contact-title">Siap Mengotomatisasi Bisnis Anda?</h2>
